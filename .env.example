# --- Shared Infrastructure ---
POSTGRES_DB=traffic
POSTGRES_USER=user
POSTGRES_PASSWORD=pass

# --- Kafka ---
KAFKA_BROKER_ID=1
KAFKA_ZOOKEEPER_CONNECT=zookeeper:2181

# --- B2 Data & Intelligence ---
KAFKA_BROKERS=kafka:9092
KAFKA_TOPIC_INPUT=traffic.events.raw
POSTGRES_URL=postgresql://user:pass@postgres:5432/traffic
WINDOW_SIZE_SECONDS=5

